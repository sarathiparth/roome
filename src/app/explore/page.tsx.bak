// ─── Generate AI insights from person data ────────────────────────────────────
function getInsights(person: Person): { pros: string[]; caution: string | null } {
  const lf = person.lifestyle ?? []
  const pros: string[] = []
  let caution: string | null = null

  if (lf.includes("Non-smoker")) pros.push("Smoke-free home")
  if (lf.includes("Early Bird") || lf.includes("Early Riser")) pros.push("Synced morning schedule")
  if (lf.includes("WFH")) pros.push("Work-from-home compatible")
  if (lf.includes("Vegetarian")) pros.push("Vegetarian-friendly kitchen")
  if (lf.includes("Minimalist") || lf.includes("Clean Freak")) pros.push("Values clean shared spaces")
  if (lf.includes("Teetotaler")) pros.push("Sober home environment")
  if (lf.includes("Homebody")) pros.push("Low-traffic, calm home life")
  if (pros.length < 2 && person.matchScore >= 85) pros.push("High lifestyle compatibility")
  if (pros.length < 2) pros.push("Budget aligns with your range")

  if (lf.includes("Night Owl") || lf.includes("Late nights")) caution = "May have different sleep schedules"
  else if (lf.includes("Smoker")) caution = "Smoker — check ventilation compatibility"
  else if (lf.includes("Gamer")) caution = "Occasional noisy gaming sessions"

  return { pros: pros.slice(0, 3), caution }
}

// ─── Enhanced animated match score ring ───────────────────────────────────────
function MatchScoreHero({ score }: { score: number }) {
  const r = 52
  const circ = 2 * Math.PI * r
  const offset = circ - (score / 100) * circ
  const color = score >= 90 ? "#34d399" : score >= 80 ? "#818cf8" : "#fbbf24"
  const label = score >= 90 ? "Excellent match" : score >= 80 ? "Great match" : "Good match"

  return (
    <div className="flex flex-col items-center gap-2">
      <div className="relative flex items-center justify-center w-32 h-32">
        {/* Pulse glow */}
        <motion.div
          className="absolute inset-0 rounded-full"
          animate={{ opacity: [0.3, 0.7, 0.3], scale: [1, 1.12, 1] }}
          transition={{ duration: 2.5, repeat: Infinity, ease: "easeInOut" }}
          style={{ background: `radial-gradient(circle, ${color}30 0%, transparent 70%)` }}
        />
        <svg className="absolute inset-0 -rotate-90 w-full h-full" viewBox="0 0 120 120" fill="none">
          <circle cx="60" cy="60" r={r} stroke="rgba(255,255,255,0.07)" strokeWidth="5" />
          <motion.circle
            cx="60" cy="60" r={r}
            stroke={color}
            strokeWidth="5"
            strokeLinecap="round"
            strokeDasharray={circ}
            initial={{ strokeDashoffset: circ }}
            animate={{ strokeDashoffset: offset }}
            transition={{ duration: 1.6, ease: "easeOut", delay: 0.3 }}
            fill="none"
            style={{ filter: `drop-shadow(0 0 8px ${color}80)` }}
          />
        </svg>
        <div className="flex flex-col items-center z-10">
          <motion.span
            className="font-black text-3xl text-white leading-none"
            initial={{ opacity: 0, scale: 0.5 }}
            animate={{ opacity: 1, scale: 1 }}
            transition={{ delay: 0.5, type: "spring", stiffness: 300 }}
          >
            {score}
          </motion.span>
          <span className="text-white/40 text-[10px] font-bold uppercase tracking-widest">match</span>
        </div>
      </div>
      <motion.span
        initial={{ opacity: 0, y: 6 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 1 }}
        className="text-xs font-semibold"
        style={{ color }}
      >
        {label}
      </motion.span>
    </div>
  )
}

// ─── Animated floating tag pill ───────────────────────────────────────────────
function FloatingTag({ label, index, delay }: { label: string; index: number; delay: number }) {
  const p = TAG_PALETTES[index % TAG_PALETTES.length]
  return (
    <motion.span
      initial={{ opacity: 0, y: 12, scale: 0.85 }}
      animate={{ opacity: 1, y: 0, scale: 1 }}
      transition={{ delay, type: "spring", stiffness: 320, damping: 24 }}
      className="px-3 py-1.5 rounded-full text-[11px] font-bold whitespace-nowrap cursor-default"
      style={{
        background: p.bg,
        border: `1px solid ${p.border}`,
        color: p.text,
        boxShadow: `0 0 14px ${p.glow}`,
      }}
      whileHover={{ scale: 1.08, boxShadow: `0 0 22px ${p.glow}` }}
    >
      {label}
    </motion.span>
  )
}

// ─── Expandable lifestyle tag ─────────────────────────────────────────────────
function ExpandableTag({ label, index }: { label: string; index: number }) {
  const [open, setOpen] = useState(false)
  const detail = LIFESTYLE_DETAILS[label]
  const p = TAG_PALETTES[index % TAG_PALETTES.length]

  return (
    <motion.button
      layout
      onClick={() => setOpen(v => !v)}
      className="flex items-start gap-2 w-full text-left rounded-2xl px-3.5 py-2.5 transition-all"
      style={{
        background: open ? p.bg : "rgba(255,255,255,0.04)",
        border: `1px solid ${open ? p.border : "rgba(255,255,255,0.09)"}`,
        boxShadow: open ? `0 0 18px ${p.glow}` : "none",
      }}
      whileTap={{ scale: 0.97 }}
      whileHover={{ background: p.bg }}
    >
      <span className="text-xs font-semibold mt-0.5 flex-shrink-0" style={{ color: open ? p.text : "rgba(255,255,255,0.7)" }}>
        {label}
      </span>
      <div className="ml-auto flex-shrink-0 mt-0.5">
        <motion.div animate={{ rotate: open ? 90 : 0 }} transition={{ duration: 0.2 }}>
          <ChevronRight className="h-3 w-3 text-white/30" />
        </motion.div>
      </div>
      <AnimatePresence>
        {open && detail && (
          <motion.span
            key="detail"
            initial={{ opacity: 0, height: 0 }}
            animate={{ opacity: 1, height: "auto" }}
            exit={{ opacity: 0, height: 0 }}
            className="text-[11px] text-white/50 leading-relaxed block"
            style={{ color: p.text }}
          >
            {detail}
          </motion.span>
        )}
      </AnimatePresence>
    </motion.button>
  )
}

// ─── AI Insight card ──────────────────────────────────────────────────────────
function AIInsightCard({ person }: { person: Person }) {
  const { pros, caution } = getInsights(person)

  return (
    <div className="w-full flex flex-col gap-3">
      <div className="flex items-center gap-2">
        <motion.div
          animate={{ opacity: [0.6, 1, 0.6] }}
          transition={{ duration: 2, repeat: Infinity }}
        >
          <Sparkles className="h-3.5 w-3.5" style={{ color: "#f59e0b" }} />
        </motion.div>
        <h3
          className="text-[10px] uppercase font-black tracking-widest"
          style={{ color: "rgba(245,158,11,0.7)" }}
        >
          AI Match Insight
        </h3>
      </div>

      {/* Divider with golden tint */}
      <div
        className="w-full h-px rounded-full"
        style={{ background: "linear-gradient(90deg, transparent, rgba(245,158,11,0.4), transparent)" }}
      />

      <div className="flex flex-col gap-2.5">
        {pros.map((pro, i) => (
          <motion.div
            key={pro}
            initial={{ opacity: 0, x: -10 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ delay: 0.3 + i * 0.1 }}
            className="flex items-center gap-2.5"
          >
            <CheckCircle2 className="h-3.5 w-3.5 flex-shrink-0" style={{ color: "#f59e0b" }} />
            <span className="text-white/75 text-[13px]">{pro}</span>
          </motion.div>
        ))}
        {caution && (
          <motion.div
            initial={{ opacity: 0, x: -10 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ delay: 0.5 }}
            className="flex items-start gap-2.5 mt-0.5"
          >
            <AlertTriangle className="h-3.5 w-3.5 flex-shrink-0 mt-0.5" style={{ color: "rgba(245,158,11,0.55)" }} />
            <span className="text-[12px]" style={{ color: "rgba(245,158,11,0.6)" }}>{caution}</span>
          </motion.div>
        )}
      </div>
    </div>
  )
}

// ─── Hero info card (bio + tags + score + intent) ────────────────────────────
