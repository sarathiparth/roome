  const scoreColor = person.matchScore >= 90 ? "#34d399" : person.matchScore >= 80 ? "#818cf8" : "#fbbf24"

  return (
    <div className="w-full flex flex-col gap-4">
      {/* Match score hero — centred above everything */}
      <div className="flex justify-center pt-1">
        <MatchScoreHero score={person.matchScore} />
      </div>

      {/* Animated gradient glow strip */}
      <motion.div
        className="w-full h-px rounded-full"
        style={{
          background: `linear-gradient(90deg, transparent, ${scoreColor}80, transparent)`,
        }}
        animate={{ opacity: [0.4, 1, 0.4] }}
        transition={{ duration: 2.5, repeat: Infinity }}
      />

      {/* Bio — quote style */}
      <motion.p
        initial={{ opacity: 0, y: 8 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 0.4 }}
        className="text-white/90 text-[17px] leading-relaxed font-medium italic text-center px-2"
        style={{ textShadow: "0 1px 20px rgba(255,255,255,0.08)" }}
      >
        &ldquo;{person.bio}&rdquo;
      </motion.p>

      {/* Floating tags */}
      <div className="flex flex-wrap gap-2 justify-center">
        {person.tags.map((t, i) => (
          <FloatingTag key={t} label={t} index={i} delay={0.5 + i * 0.12} />
        ))}
      </div>

      {/* Divider */}
      <div className="border-t border-white/[0.07]" />

      {/* Intent + budget */}
      <div className="flex items-center justify-between">
        <div
          className="flex items-center gap-1.5 px-3 py-1.5 rounded-full"
          style={{ background: "rgba(255,255,255,0.06)", border: "1px solid rgba(255,255,255,0.1)" }}
        >
          <span className="text-white/50 flex">{intentIcon[person.intent]}</span>
          <span className="text-white/60 text-[11px] font-semibold">{intentLabel[person.intent]}</span>
        </div>
        <div className="flex flex-col items-end">
          <span className="text-white font-black text-lg leading-none">
            ₹{person.budget.toLocaleString("en-IN")}
          </span>
          <span className="text-white/35 text-[10px]">per month</span>
        </div>
      </div>
    </div>
  )
}

// ─── Prompt card with icon ────────────────────────────────────────────────────
function PromptCard({ question, answer }: { question: string; answer: string }) {
  const icon = PROMPT_ICONS[question] ?? "💬"
  return (
    <div className="flex flex-col gap-3">
      <div className="flex items-center gap-2">
        <span className="text-base leading-none">{icon}</span>
